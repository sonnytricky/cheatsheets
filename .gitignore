##############################################
# Verzeichnisse wieder erlauben
##############################################
!*/

##############################################
# Ordner ignorieren
##############################################
# /.Releases/
# *.Releases/
# !*/.Releases/
# /.aLT/
# *.aLT/
# !*/.aLT/

##############################################
# Verzeichnisse wieder erlauben                  # !*/Unterordner/
##############################################
!*/.docs/Anleitungen/
!*/.gitea/ISSUE_TEMPLATE/
!*/.gitea/workflows/
!*/.github/ISSUE_TEMPLATE/
